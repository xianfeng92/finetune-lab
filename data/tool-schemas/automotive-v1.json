{
  "version": "v1-demo",
  "domains": {
    "hvac": [
      {
        "name": "hvac_set_temperature",
        "description": "Set HVAC target temperature.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["zone", "celsius"],
          "properties": {
            "zone": { "type": "string", "enum": ["driver", "passenger", "rear"] },
            "celsius": { "type": "number", "minimum": 16, "maximum": 30 }
          }
        }
      },
      {
        "name": "hvac_set_fan_speed",
        "description": "Set fan speed level.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["zone", "level"],
          "properties": {
            "zone": { "type": "string", "enum": ["driver", "passenger", "rear"] },
            "level": { "type": "integer", "minimum": 1, "maximum": 7 }
          }
        }
      }
    ],
    "window": [
      {
        "name": "window_set_open_percent",
        "description": "Set a window open percentage.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["position", "percent"],
          "properties": {
            "position": { "type": "string", "enum": ["front_left", "front_right", "rear_left", "rear_right", "all"] },
            "percent": { "type": "integer", "minimum": 0, "maximum": 100 }
          }
        }
      }
    ],
    "seat": [
      {
        "name": "seat_set_heating",
        "description": "Set seat heating level.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["position", "level"],
          "properties": {
            "position": { "type": "string", "enum": ["driver", "passenger", "rear_left", "rear_right"] },
            "level": { "type": "integer", "minimum": 0, "maximum": 3 }
          }
        }
      }
    ],
    "door": [
      {
        "name": "door_set_lock",
        "description": "Lock or unlock door(s).",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["position", "locked"],
          "properties": {
            "position": { "type": "string", "enum": ["front_left", "front_right", "rear_left", "rear_right", "all"] },
            "locked": { "type": "boolean" }
          }
        }
      }
    ],
    "lighting": [
      {
        "name": "lighting_set_ambient",
        "description": "Set ambient cabin lighting state and color.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["on", "color"],
          "properties": {
            "on": { "type": "boolean" },
            "color": {
              "type": "string",
              "enum": ["purple", "blue", "red", "yellow", "white", "brown", "green", "orange"]
            }
          }
        }
      },
      {
        "name": "lighting_set_headlight_beam",
        "description": "Set headlight beam state.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["beam", "on"],
          "properties": {
            "beam": { "type": "string", "enum": ["low", "high"] },
            "on": { "type": "boolean" }
          }
        }
      },
      {
        "name": "lighting_set_fog_lights",
        "description": "Turn fog lights on or off.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["on"],
          "properties": {
            "on": { "type": "boolean" }
          }
        }
      }
    ],
    "navigation": [
      {
        "name": "navigation_set_destination",
        "description": "Start navigation using a natural-language destination query.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["destination_query"],
          "properties": {
            "destination_query": { "type": "string", "minLength": 1 }
          }
        }
      },
      {
        "name": "navigation_set_route",
        "description": "Apply a precomputed route sequence to navigation.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["route_ids"],
          "properties": {
            "route_ids": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      {
        "name": "navigation_replace_final_destination",
        "description": "Replace the current final destination in an active route.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["new_destination_id", "route_id_leading_to_new_destination"],
          "properties": {
            "new_destination_id": { "type": "string", "minLength": 1 },
            "route_id_leading_to_new_destination": { "type": "string", "minLength": 1 }
          }
        }
      },
      {
        "name": "navigation_delete_destination",
        "description": "Delete the current final destination from an active route.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["destination_id_to_delete"],
          "properties": {
            "destination_id_to_delete": { "type": "string", "minLength": 1 }
          }
        }
      },
      {
        "name": "navigation_delete_waypoint",
        "description": "Delete a waypoint from an active route.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["waypoint_id_to_delete", "route_id_without_waypoint"],
          "properties": {
            "waypoint_id_to_delete": { "type": "string", "minLength": 1 },
            "route_id_without_waypoint": { "type": "string", "minLength": 1 }
          }
        }
      },
      {
        "name": "navigation_replace_waypoint",
        "description": "Replace one waypoint in an active route with another.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "waypoint_id_to_replace",
            "new_waypoint_id",
            "route_id_leading_to_new_waypoint",
            "route_id_leading_away_from_new_waypoint"
          ],
          "properties": {
            "waypoint_id_to_replace": { "type": "string", "minLength": 1 },
            "new_waypoint_id": { "type": "string", "minLength": 1 },
            "route_id_leading_to_new_waypoint": { "type": "string", "minLength": 1 },
            "route_id_leading_away_from_new_waypoint": { "type": "string", "minLength": 1 }
          }
        }
      },
      {
        "name": "navigation_add_waypoint",
        "description": "Add a waypoint into an active route.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "waypoint_id_before_new_waypoint",
            "route_id_leading_to_new_waypoint",
            "route_id_leading_away_from_new_waypoint",
            "waypoint_id_to_add",
            "waypoint_id_after_new_waypoint"
          ],
          "properties": {
            "waypoint_id_before_new_waypoint": { "type": "string", "minLength": 1 },
            "route_id_leading_to_new_waypoint": { "type": "string", "minLength": 1 },
            "route_id_leading_away_from_new_waypoint": { "type": "string", "minLength": 1 },
            "waypoint_id_to_add": { "type": "string", "minLength": 1 },
            "waypoint_id_after_new_waypoint": { "type": "string", "minLength": 1 }
          }
        }
      }
    ],
    "media": [
      {
        "name": "media_play_content",
        "description": "Play audio content from a natural-language query.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["query"],
          "properties": {
            "query": { "type": "string", "minLength": 1 },
            "source": { "type": "string", "enum": ["playlist", "album", "artist", "radio", "generic"] }
          }
        }
      }
    ],
    "meta": [
      {
        "name": "_meta_reroute",
        "description": "Suggest different domain(s) when loaded tools do not fit the user intent.",
        "parameters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["suggested_domains", "reason"],
          "properties": {
            "suggested_domains": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "enum": ["hvac", "window", "seat", "door", "lighting", "navigation", "media"] }
            },
            "reason": { "type": "string", "minLength": 1 }
          }
        }
      }
    ]
  },
  "events": [
    { "id": "evt-cabin-cold", "domain": "hvac", "signal": "cabin_temperature_low", "description": "Cabin feels cold." },
    { "id": "evt-window-rain", "domain": "window", "signal": "rain_detected", "description": "Rain sensor triggered." },
    { "id": "evt-seat-cold", "domain": "seat", "signal": "seat_surface_cold", "description": "Seat surface is cold." },
    { "id": "evt-door-open", "domain": "door", "signal": "door_left_open", "description": "Driver door still open." }
  ]
}
