{
  "name": "finetune-lab-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync-data": "node scripts/build-lab-data.mjs",
    "dev": "npm run sync-data && vite --host 127.0.0.1 --port 4173",
    "build": "npm run sync-data && tsc -b && vite build && node scripts/export-standalone-html.mjs",
    "build:ci": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
